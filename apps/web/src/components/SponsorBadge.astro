---
// Floating sponsor badge, shown bottom-right on every page. A holographic
// foil rendering of the Calicchia Design wordmark on a dark card — like a
// holo sticker — linking to calicchia.design. Dismissible: sponsor.ts
// remembers the choice in localStorage and reveals the badge (hidden here
// so a dismissed visitor never sees a flash). The pointer tilt + reduced-
// motion handling also live in sponsor.ts.
import CalicchiaLogo from './CalicchiaLogo.astro';
import { translate } from '../i18n/i18n';
import type { Lang } from '../i18n/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'it' } = Astro.props;
const kicker = translate(lang, 'sponsor.kicker');
const closeLabel = translate(lang, 'sponsor.close');
---

<aside class="sponsor" id="sponsor" hidden aria-label={kicker}>
  <button
    type="button"
    class="sponsor-close"
    id="sponsor-close"
    aria-label={closeLabel}
    title={closeLabel}
  >
    <svg viewBox="0 0 12 12" aria-hidden="true"><path d="M2 2l8 8M10 2l-8 8" /></svg>
  </button>
  <a
    class="sponsor-card"
    id="sponsor-card"
    href="https://calicchia.design"
    target="_blank"
    rel="noopener sponsored"
  >
    <span class="sponsor-kicker mono" data-i18n="sponsor.kicker">{kicker}</span>
    <CalicchiaLogo class="sponsor-logo" />
    <span class="sponsor-sheen" aria-hidden="true"></span>
  </a>
</aside>

---
// Shared converter markup. Two shapes:
// - instant (landing): chips + dropzone + results. No panel, no queue —
//   the demo converts one file with defaults and celebrates it.
// - studio (/convert): machine preset + chips + extra formats + dropzone,
//   then the queue and the detail panel. converter.ts/panel.ts/queue.ts
//   own every id in here.
interface Props {
  mode: 'instant' | 'studio';
}
const { mode } = Astro.props;
const studio = mode === 'studio';
---

<div class="conv-body">
  <div class="conv-side">
    {studio && (
      <div class="toolbar-field">
        <label class="panel-label mono" for="preset-select" data-i18n="tool.presetLabel">La tua macchina</label>
        <select id="preset-select" class="hoop-select preset-select"></select>
      </div>
    )}
    <div class="target-field">
      <p class="target-label mono" data-i18n="conv.targetLabel">Cuci in formato</p>
      <ul id="format-chips" class="chips"></ul>
    </div>
    {studio && (
      <fieldset id="extra-field" class="toolbar-field extra-field">
        <legend class="panel-label mono" data-i18n="tool.extraLabel">Esporta anche in</legend>
        <ul id="extra-formats" class="extra-formats"></ul>
      </fieldset>
    )}
    <p id="accept-hint" class="hint mono"></p>
    {!studio && (
      <a class="btn btn-ghost conv-full-link" href="/convert" data-i18n="conv.fullLink">Apri il Convertitore completo →</a>
    )}
  </div>
  <div
    id="dropzone"
    class="dropzone"
    tabindex="0"
    role="button"
    data-i18n-aria="conv.dropAria"
  >
    <svg class="stitch-border" aria-hidden="true" preserveAspectRatio="none">
      <rect x="6" y="6" rx="14" pathLength="100"></rect>
    </svg>
    <p class="drop-title" data-i18n="conv.dropTitle">Trascina qui i tuoi file di ricamo</p>
    <p class="drop-sub" data-i18n="conv.dropSub">oppure clicca per sceglierli</p>
    <input id="file-input" type="file" multiple hidden />
  </div>
</div>

{studio && (
  <div id="queue-bar" class="queue-bar" hidden>
    <p id="queue-count" class="queue-count mono"></p>
    <button id="convert-all-btn" type="button" class="btn btn-primary">Converti tutto</button>
  </div>
)}
{studio && <ul id="queue" class="queue" hidden></ul>}

{studio && (
  <section id="preview-panel" class="preview-panel" hidden>
    <div class="preview-window">
      <div id="preview-canvas" role="img"></div>
    </div>
    <div class="preview-side">
      <p id="preview-name" class="mono preview-name"></p>
      <dl id="preview-info" class="preview-info"></dl>

      <div id="thread-field" class="panel-field" hidden>
        <p class="panel-label mono" data-i18n="panel.threadsLabel">Fili</p>
        <ul id="thread-list" class="thread-list"></ul>
      </div>

      <div id="hoop-field" class="panel-field" hidden>
        <label class="mono panel-label" for="hoop-select" data-i18n="panel.hoopLabel">Telaio di destinazione</label>
        <select id="hoop-select" class="hoop-select"></select>
        <p id="hoop-fit" class="panel-fit"></p>
      </div>

      <fieldset id="trims-field" class="panel-field trims-field" hidden>
        <legend class="mono panel-label" data-i18n="panel.trimsLabel">Tagli del filo</legend>
        <label class="trims-option">
          <input type="radio" name="trims" value="drop" checked />
          <span class="trims-copy">
            <strong data-i18n="panel.trimsDrop">Fili volanti</strong>
            <small data-i18n="panel.trimsDropHint">La macchina non si ferma: i fili tra i blocchi li spunti a fine lavoro.</small>
            <small id="trims-drop-stops" class="mono trims-stops"></small>
          </span>
        </label>
        <label class="trims-option">
          <input type="radio" name="trims" value="pause" />
          <span class="trims-copy">
            <strong data-i18n="panel.trimsPause">Pausa a ogni taglio</strong>
            <small data-i18n="panel.trimsPauseHint">La macchina si ferma a ogni taglio, così spunti il filo subito.</small>
            <small id="trims-pause-stops" class="mono trims-stops"></small>
          </span>
        </label>
      </fieldset>

      <label id="center-field" class="panel-check" hidden>
        <input id="center-check" type="checkbox" />
        <span data-i18n="panel.center">Centra nel telaio</span>
      </label>

      <p id="panel-note" class="panel-note" hidden></p>
      <div class="panel-actions">
        <button id="convert-btn" type="button" class="btn btn-primary">Converti</button>
        <button id="discard-btn" type="button" class="btn btn-ghost" data-i18n="panel.remove">Rimuovi dalla coda</button>
      </div>
    </div>
  </section>
)}

{!studio && <ul id="results" class="results" hidden></ul>}

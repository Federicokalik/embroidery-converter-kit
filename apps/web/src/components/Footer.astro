---
// Shared footer used by both pages. Reads texts from the i18n keys so the
// entries stay in one dictionary; only the markup is shared. The pink
// sponsor card points at Calicchia.Design (no P.Iva, just indirect ad).
import { withBase } from '../core/base';
---

<footer class="footer site-footer">
  <div class="footer-inner">
    <span class="wordmark-footer">Ricuci</span>
    <p class="footer-tagline" data-i18n="footer.tagline">
      Ricuci i tuoi ricami in un altro formato.
    </p>

    <nav class="footer-links" aria-label="Footer">
      <a href={withBase('docs/')} data-i18n="footer.docsLink">Come funziona Ricuci</a>
      <a href={withBase('docs/formats/')} data-i18n="footer.formatsLink">Formati supportati</a>
      <a href={withBase('docs/privacy/')} data-i18n="footer.privacyLink">Privacy</a>
    </nav>

    <a
      class="footer-sponsor"
      href="https://calicchia.design"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="footer-sponsor-label mono" data-i18n="footer.sponsorBy">Sostenuto da</span>
      <span class="footer-sponsor-badge">
        <span class="footer-sponsor-text">Calicchia.Design</span>
        <svg
          class="footer-sponsor-arrow"
          viewBox="0 0 12 12"
          aria-hidden="true"
          fill="none"
        >
          <path d="M3 9 L9 3 M9 3 H4 M9 3 V8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>

    <p class="footer-credit mono" data-i18n="footer.credit">Design e codice: Federico</p>
    <!-- The page-long pink thread ends here, in a small knot. -->
    <svg class="footer-knot" viewBox="0 0 44 32" aria-hidden="true">
      <path d="M2 16 C 10 4 20 4 24 14 C 27 22 18 26 15 19 C 12 12 24 8 32 12 C 40 16 42 22 42 28"></path>
    </svg>
  </div>
</footer>
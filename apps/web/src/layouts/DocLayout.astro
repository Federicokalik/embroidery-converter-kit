---
// Shared layout for every docs page. Left sidebar with a hand-written
// index, main column with <slot />, <Footer /> at the bottom. The docs
// exist in it (at /docs/) and en (at /en/docs/): pass lang and the page's
// logical path so links, hreflang and the sidebar resolve per language.
import '../styles/base.css';
import '../styles/footer.css';
import '../styles/docs.css';
import '../styles/sponsor.css';
import DocsNav from '../components/DocsNav.astro';
import Footer from '../components/Footer.astro';
import SiteHead from '../components/SiteHead.astro';
import SponsorBadge from '../components/SponsorBadge.astro';
import { DOCS_LANGS, localeUrl, pageLogicalPath } from '../i18n/i18n';
import type { Lang } from '../i18n/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}
const { lang = 'it' } = Astro.props;
const title = Astro.props.title ?? 'Ricuci — Docs';
const description =
  Astro.props.description ??
  (lang === 'it' ? 'Come funziona Ricuci, dentro e fuori.' : 'How Ricuci works, inside and out.');

interface NavItem {
  path: string; // logical, lang-less: 'docs/ir'
  label: string;
}
interface NavGroup {
  title: string;
  items: NavItem[];
}

const L = (it: string, en: string): string => (lang === 'it' ? it : en);

const groups: NavGroup[] = [
  {
    title: 'Start',
    items: [
      { path: 'docs', label: L('Panoramica', 'Overview') },
      { path: 'docs/how-it-works', label: L('Come funziona', 'How it works') },
      { path: 'docs/architecture', label: L('Architettura', 'Architecture') },
    ],
  },
  {
    title: L('Formati', 'Formats'),
    items: [
      { path: 'docs/formats', label: L('Tutti i formati', 'All formats') },
      { path: 'docs/formats/vip', label: 'VIP' },
      { path: 'docs/formats/zhs', label: 'ZHS' },
      { path: 'docs/formats/pes', label: 'PES / PEC' },
      { path: 'docs/formats/dst', label: 'DST' },
      { path: 'docs/formats/jef', label: 'JEF' },
      { path: 'docs/formats/vp3', label: 'VP3' },
      { path: 'docs/formats/exp', label: 'EXP' },
    ],
  },
  {
    title: 'Internals',
    items: [
      { path: 'docs/ir', label: 'Intermediate Representation' },
      { path: 'docs/embcompress', label: 'EmbCompress' },
      { path: 'docs/testing', label: L('Test & fixture', 'Tests & fixtures') },
      { path: 'docs/privacy', label: 'Privacy' },
    ],
  },
];

// Active item: compare logical paths (base- and lang-independent).
const here = pageLogicalPath(Astro.url.pathname).replace(/\/$/, '');
const isActive = (path: string): boolean => here === path;
const logical = `${here}/`;
---

<!doctype html>
{/* data-theme="light": the site identity is light-only; without this Pico
    follows prefers-color-scheme and flips the docs to its dark palette. */}
<html lang={lang} data-theme="light">
  <head>
    <SiteHead
      lang={lang}
      logical={logical}
      title={title}
      description={description}
      availableLangs={DOCS_LANGS}
    />
  </head>
  <body>
    <DocsNav lang={lang} />

    <main class="docs-shell">
      <aside class="docs-sidebar" aria-label={L('Indice', 'Index')}>
        {groups.map((group) => (
          <nav>
            <h2>{group.title}</h2>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a href={localeUrl(lang, `${item.path}/`)} aria-current={isActive(item.path) ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))}
      </aside>

      <article class="docs-body">
        <slot />
      </article>
    </main>

    <Footer lang={lang} />

    <SponsorBadge lang={lang} />

    <script>
      import { applyI18n } from '../i18n/i18n';
      import { initLangSwitch } from '../i18n/lang-switch';
      import { initSponsor } from '../sponsor';
      applyI18n();
      initLangSwitch();
      initSponsor();
    </script>
  </body>
</html>

---
// CSS imported here (not in main.ts) so Astro serves it from <head> in dev
// and build alike: first paint is always the styled preloader, no FOUC.
import '../styles/base.css';
import '../styles/scenes.css';
import '../styles/converter.css';
import '../styles/preloader.css';
import ConverterSection from '../components/ConverterSection.astro';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restitch, il convertitore di ricami nel browser</title>
    <meta
      name="description"
      content="Converti i tuoi file da ricamo (VIP, ZHS, PES, DST, JEF e altri) direttamente nel browser. I file non lasciano mai il tuo computer."
    />
    <link rel="preload" href="/fonts/ClashDisplay-Semibold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Satoshi-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ff2e88' stroke-width='2.4' stroke-linecap='round'%3E%3Cpath d='M3 17 Q7 13 12 15 T21 11'/%3E%3Cpath d='M17 4 l3 3 M20 4 l-3 3'/%3E%3C/svg%3E"
    />
  </head>
  <body>
    <!-- Persistent stitch stage: the pink thread lives here (2D or WebGL). -->
    <div id="stage" aria-hidden="true"></div>

    <nav class="nav" aria-label="Restitch">
      <a class="wordmark" href="#hero">
        Restitch
        <svg class="wordmark-stitch" viewBox="0 0 120 8" aria-hidden="true" preserveAspectRatio="none">
          <path d="M2 5 Q16 1 30 5 T58 5 T86 5 T114 5" pathLength="1"></path>
        </svg>
      </a>
      <div class="nav-right">
        <div class="lang-switch" role="group" data-i18n-aria="nav.langLabel">
          <button type="button" data-lang="it">IT</button>
          <button type="button" data-lang="en">EN</button>
        </div>
        <a class="btn btn-primary nav-cta" href="/convert" data-i18n="nav.cta">Converti ora</a>
      </div>
    </nav>

    <main>
      <!-- S1: the letter A stitches itself on the stage, right column. -->
      <header class="scene scene-hero" id="hero">
        <div class="scene-inner">
          <div class="hero-copy">
            <h1 class="display" data-i18n="hero.headline">Il tuo ricamo parla ogni lingua.</h1>
            <p class="hero-tech mono" data-i18n="hero.tech">
              VIP, PES, DST e altri. Convertiti dentro il tuo browser.
            </p>
            <div class="hero-ctas">
              <a class="btn btn-primary" href="/convert" data-i18n="hero.cta">Converti ora</a>
              <a class="btn btn-ghost" href="#babel" data-i18n="hero.learn">Scopri di più</a>
            </div>
          </div>
          <div class="hero-stagehold" data-stagehold="hero" aria-hidden="true"></div>
        </div>
      </header>

      <!-- S2: camera dollies across three stations (A, B, Z) on the stage. -->
      <section class="scene scene-babel" id="babel">
        <div class="scene-inner">
          <h2 class="display" data-i18n="babel.headline">Ogni macchina parla la sua lingua.</h2>
          <!-- Stations match the real designs on stage (see fixtures.ts). -->
          <ul class="babel-stations">
            <li>
              <span class="ext mono">.pes</span>
              <span class="brand">Brother</span>
            </li>
            <li>
              <span class="ext mono">.jef</span>
              <span class="brand">Janome</span>
            </li>
            <li>
              <span class="ext mono">.dst</span>
              <span class="brand">Tajima</span>
            </li>
          </ul>
          <div class="babel-stagehold" data-stagehold="babel" aria-hidden="true"></div>
        </div>
      </section>

      <!-- S3: the B re-stitches while its real coordinates stream by. -->
      <section class="scene scene-translation" id="translation">
        <div class="scene-inner">
          <h2 class="display" data-i18n="translation.headline">
            Restitch le traduce tutte. Punto per punto.
          </h2>
          <div class="coord-stream mono" id="coord-stream" aria-hidden="true"></div>
        </div>
      </section>

      <!-- S4: horizontal typographic wall of every supported format. -->
      <section class="scene scene-atoz" id="atoz">
        <div class="scene-inner">
          <h2 class="display" data-i18n="atoz.headline">Dalla A alla Z.</h2>
          <p class="atoz-sub mono" id="atoz-sub"></p>
        </div>
        <div class="format-wall-wrap">
          <ul id="format-wall" class="format-wall display"></ul>
        </div>
      </section>

      <!-- S5: macro dive between the thread crossings. -->
      <section class="scene scene-precision" id="precision">
        <div class="scene-inner">
          <h2 class="display" data-i18n="precision.headline">Ogni punto resta al suo posto.</h2>
          <div class="precision-compare mono">
            <span class="label" data-i18n="precision.before">prima</span>
            <span class="label" data-i18n="precision.after">dopo</span>
            <span>21,-7</span><span>21,-7</span>
            <span>26,-11</span><span>26,-11</span>
            <span>16,-2</span><span>16,-2</span>
          </div>
        </div>
      </section>

      <div class="privacy-strip">
        <p class="mono" data-i18n="privacy.line">
          Tutto accade nel tuo browser. Niente server, niente caricamenti.
        </p>
      </div>

      <!-- S6: the destination. converter.ts owns these IDs. -->
      <section class="scene scene-finale" id="converter">
        <div class="scene-inner">
          <h2 class="display" data-i18n="finale.headline">Tocca a te.</h2>
          <ConverterSection />
        </div>
      </section>

      <footer class="footer">
        <div class="scene-inner">
          <span class="wordmark-footer">Restitch</span>
          <p class="footer-tagline" data-i18n="footer.tagline">
            Ricuci i tuoi ricami in un altro formato.
          </p>
          <p class="footer-credit mono" data-i18n="footer.credit">Design e codice: Federico</p>
          <!-- The page-long pink thread ends here, in a small knot. -->
          <svg class="footer-knot" viewBox="0 0 44 32" aria-hidden="true">
            <path d="M2 16 C 10 4 20 4 24 14 C 27 22 18 26 15 19 C 12 12 24 8 32 12 C 40 16 42 22 42 28"></path>
          </svg>
        </div>
      </footer>
    </main>

    <!-- Stitch-out overlay: the machine sews the user's real design. -->
    <div id="stitchout" class="stitchout" hidden>
      <div class="stitchout-panel" role="dialog" aria-modal="true" aria-labelledby="stitchout-status">
        <div class="stitchout-stage">
          <div id="stitchout-canvas" class="stitchout-canvas"></div>
          <svg class="stitchout-head" viewBox="0 0 240 150" aria-hidden="true" fill="none">
            <path class="so-arm" d="M14 10 H166 C186 10 196 22 196 42 V64 C196 80 186 88 170 88 H142"></path>
            <g id="so-needle">
              <path class="so-bar" d="M120 88 V112"></path>
              <path class="so-tip" d="M120 112 V134"></path>
              <path class="so-thread" d="M120 10 V112"></path>
            </g>
            <path class="so-foot" d="M104 138 h32 M112 138 v-10 h16"></path>
          </svg>
        </div>
        <p id="stitchout-status" class="stitchout-status mono"></p>
        <div class="stitchout-actions">
          <button id="stitchout-skip" type="button" class="btn btn-ghost" data-i18n="stitch.skip">
            Salta e scarica
          </button>
        </div>
      </div>
    </div>

    <!-- Preloader: the wordmark stitches in while fonts + fixtures load. -->
    <div id="preloader" class="preloader">
      <div class="preloader-inner">
        <span class="preloader-word display" aria-hidden="true">Restitch</span>
        <svg class="preloader-stitch" viewBox="0 0 240 10" preserveAspectRatio="none" aria-hidden="true">
          <path id="preloader-path" d="M2 6 Q22 1 42 6 T82 6 T122 6 T162 6 T202 6 T238 6"></path>
        </svg>
        <span id="preloader-pct" class="preloader-pct mono" aria-hidden="true">000</span>
      </div>
    </div>
    <noscript><style is:inline>.preloader { display: none; }</style></noscript>

    <script>
      import '../main';
    </script>
  </body>
</html>

---
// Non-default locales of the studio (/en/convert/, /fr/convert/, ...).
// Web build → the full page; desktop build → the app-shell studio.
import ConvertPage from '../../components/pages/ConvertPage.astro';
import ConvertStudio from '../../components/pages/ConvertStudio.astro';
import { isDesktop } from '../../lib/target';
import { LANGS } from '../../i18n/i18n';
import type { Lang } from '../../i18n/i18n';

export function getStaticPaths(): Array<{ params: { lang: string } }> {
  return LANGS.filter((l) => l.code !== 'it').map((l) => ({ params: { lang: l.code } }));
}

const lang = Astro.params.lang as Lang;
---

{isDesktop ? <ConvertStudio lang={lang} /> : <ConvertPage lang={lang} />}

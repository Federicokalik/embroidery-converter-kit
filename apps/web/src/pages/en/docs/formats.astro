        <th>Brand</th>
        <th>Reads</th>
        <th>Writes</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><a href={withBase('en/docs/formats/vip')}>VIP</a></td>
        <td>Husqvarna / PFAFF</td>
        <td>✓</td>
        <td>✓</td>
        <td>HUS body compressed with EmbCompress, no XOR.</td>
      </tr>
      <tr>
        <td><a href={withBase('en/docs/formats/zhs')}>ZHS</a></td>
        <td>Husqvarna (newer)</td>
        <td>✓</td>
        <td>✓</td>
        <td>Reverse-engineered writer. The first open writer in the world.</td>
      </tr>
      <tr>
        <td>HUS</td>
        <td>Husqvarna (old)</td>
        <td>✓</td>
        <td>✓</td>
        <td>EmbCompress, without the VIP wrapper.</td>
      </tr>
      <tr>
        <td>XXX</td>
        <td>Melco / Barudan</td>

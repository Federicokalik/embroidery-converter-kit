    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Federicokalik/embroidery-converter-kit/issues"
  },
  "keywords": [
    "embroidery",
    "converter",
    "cli",
    "vip",
    "zhs",
    "pes",
    "dst",
    "jef",
    "vp3",
    "hus",
    "exp",
    "pec",
    "stitch",
